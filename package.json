{
  "name": "babylon-crm",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:all": "npm run dev",
    "dev:api": "npm --workspace @babylon/api exec -- tsx watch src/main.ts",
    "dev:web": "npm --workspace web run dev",
    "build": "npm run build --workspaces --if-present",
    "dev": "node scripts/dev-all.mjs",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.4.2",
    "@types/node": "^20.11.24"
  }
}
