{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "workflows": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "entity_type": {
                        "type": "string"
                    },
                    "version": {
                        "type": "integer"
                    },
                    "states": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "description": {
                                    "type": "string"
                                },
                                "is_initial": {
                                    "type": "boolean"
                                },
                                "is_terminal": {
                                    "type": "boolean"
                                }
                            },
                            "required": [
                                "name"
                            ]
                        }
                    },
                    "transitions": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "key": {
                                    "type": "string"
                                },
                                "name": {
                                    "type": "string"
                                },
                                "from_state": {
                                    "type": "string"
                                },
                                "to_state": {
                                    "type": "string"
                                },
                                "trigger": {
                                    "type": "object",
                                    "properties": {
                                        "actor_type": {
                                            "type": "array",
                                            "items": {
                                                "type": "string",
                                                "enum": [
                                                    "customer",
                                                    "internal",
                                                    "system"
                                                ]
                                            }
                                        },
                                        "permissions": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            }
                                        }
                                    },
                                    "required": [
                                        "actor_type"
                                    ]
                                },
                                "guards": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "name": {
                                                "type": "string"
                                            },
                                            "params": {
                                                "type": "object"
                                            }
                                        },
                                        "required": [
                                            "name"
                                        ]
                                    }
                                },
                                "effects": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "name": {
                                                "type": "string"
                                            },
                                            "params": {
                                                "type": "object"
                                            }
                                        },
                                        "required": [
                                            "name"
                                        ]
                                    }
                                },
                                "requires_approval": {
                                    "type": "boolean"
                                }
                            },
                            "required": [
                                "key",
                                "name",
                                "from_state",
                                "to_state",
                                "trigger"
                            ]
                        }
                    }
                },
                "required": [
                    "id",
                    "name",
                    "entity_type",
                    "version",
                    "states",
                    "transitions"
                ]
            }
        }
    },
    "required": [
        "workflows"
    ]
}