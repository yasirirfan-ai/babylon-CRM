{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "sourceMap": true,
        "composite": true,
        "incremental": true,
        "isolatedModules": true
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}