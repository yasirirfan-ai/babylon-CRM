{
    "version": 2,
    "builds": [
        {
            "src": "apps/api/src/main.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "packages/workflows/workflow-pack.schema.json",
                    "packages/workflows/workflow-pack.v1.json"
                ]
            }
        },
        {
            "src": "apps/web/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/apps/api/src/main.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/dist/$1"
        }
    ],
    "installCommand": "npm install",
    "buildCommand": "npm run build"
}
